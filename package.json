{
  "name": "broken-arrow-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:init": "node src/db/initDb.js",
    "lint": "eslint .",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:fix": "prettier . --write",
    "format:check": "prettier . --check",
    "precommit:lint": "npm run lint:check",
    "precommit:format": "npm run format:check",
    "precommit": "npm run precommit:lint && npm run precommit:format",
    "prepare": "husky || true"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mysql2": "^3.12.0",
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1"
  }
}
